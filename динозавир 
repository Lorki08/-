void erasePrevDino() {
  if (prevIsDucking)
    tft.fillRect(DINO_X - 1, GROUND_Y - 13, 19, 13, COL_BLACK);
  else
    tft.fillRect(DINO_X - 1, prevDinoY - 1, 19, 18, COL_BLACK);
}

void erasePrevObs() {
  const CactusType& c = CACTUSES[prevObsType];
  tft.fillRect(prevObsX - 1, GROUND_Y - 17, c.w + 2, 18, COL_BLACK);
}

void erasePrevBird() {
  tft.fillRect(prevBirdX - 1, prevBirdY - 1, 19, 11, COL_BLACK);
}

void eraseDecor() {
  tft.fillRect(prevCloud1X, cloud1Y, 18, 9, COL_BLACK);
  tft.fillRect(prevCloud2X, cloud2Y, 18, 9, COL_BLACK);
  tft.fillRect(prevMount1X, mount1Y, 18, 9, COL_BLACK);
  tft.fillRect(prevMount2X, mount2Y, 18, 9, COL_BLACK);
}

void drawDecor() {
  // Хмари — рухаються повільно
  tft.drawBitmap(cloud1X, cloud1Y, cloud,    16, 8, AMBER_DIM);
  tft.drawBitmap(cloud2X, cloud2Y, cloud,    16, 8, AMBER_DIM);
  // Гори — рухаються дуже повільно
  tft.drawBitmap(mount1X, mount1Y, mountain, 16, 8, AMBER_DIM);
  tft.drawBitmap(mount2X, mount2Y, mountain, 16, 8, AMBER_DIM);
}

void eraseGround() {
  tft.drawFastHLine(0, GROUND_Y + 1, SCREEN_W, COL_BLACK);
  tft.drawFastHLine(0, GROUND_Y + 2, SCREEN_W, COL_BLACK);
}

void drawGround() {
  tft.drawFastHLine(0, GROUND_Y,     SCREEN_W, AMBER);
  tft.drawFastHLine(0, GROUND_Y + 1, SCREEN_W, AMBER_DIM);
  // Камінці
  int o = groundOffset % 24;
  for (int x = o - 24; x < SCREEN_W; x += 24)
    if (x >= 0 && x < SCREEN_W - 2)
      tft.drawFastHLine(x, GROUND_Y + 2, 3, AMBER_DIM);
}

void drawDino() {
  if (isDucking) {
    tft.drawBitmap(DINO_X, GROUND_Y - 12, dino_duck, 16, 16, AMBER);
  } else if (isJumping) {
    tft.drawBitmap(DINO_X, dinoY, dino_jump, 16, 16, AMBER);
  } else {
    const unsigned char* frame = (animFrame == 0) ? dino_run1 : dino_run2;
    tft.drawBitmap(DINO_X, dinoY, frame, 16, 16, AMBER);
  }
}

void drawObs() {
  const CactusType& c = CACTUSES[obsType];
  tft.drawBitmap(obsX, GROUND_Y - 16, c.bitmap, c.w, c.h, AMBER);
}

void drawBird() {
  const unsigned char* bframe = (birdAnim == 0) ? bird : bird2;
  tft.drawBitmap(birdX, birdY, bframe, 16, 8, AMBER);
}

// =============================================
// КОЛІЗІЇ
// =============================================

bool checkCactusHit() {
  const CactusType& c = CACTUSES[obsType];
  int obsTop  = (GROUND_Y - 16) + (int)c.topOffset;
  int obsBot  = GROUND_Y - 1;
  int dinoTop = isDucking ? (GROUND_Y - 12) : dinoY + 2;
  int dinoBot = isDucking ? (GROUND_Y - 2)  : (dinoY + 14);
  int dinoL   = DINO_X + 3;
  int dinoR   = DINO_X + 13;
  int obsL    = obsX + 1;
  int obsR    = obsX + (int)c.hitW;

  return (dinoR > obsL) && (dinoL < obsR) &&
         (dinoBot > obsTop) && (dinoTop < obsBot);
}

bool checkBirdHit() {
  int dinoTop = isDucking ? (GROUND_Y - 12) : dinoY + 2;
  int dinoBot = isDucking ? (GROUND_Y - 2)  : (dinoY + 14);
  return (DINO_X + 13 > birdX + 2) &&
         (DINO_X + 3  < birdX + 13) &&
         (dinoBot > birdY + 1) &&
         (dinoTop < birdY + 7);
}

