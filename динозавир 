// =============================================
// RESET
// =============================================

void resetGame() {
  score         = 0;
  speed         = 3;
  dinoY         = GROUND_Y - 16;
  prevDinoY     = GROUND_Y - 16;
  jumpVel       = 0;
  isJumping     = false;
  isDucking     = false;
  prevIsDucking = false;
  animFrame     = 0;
  animTick      = 0;
  birdAnim      = 0;
  birdAnimTick  = 0;
  obsX          = SCREEN_W + 30;
  prevObsX      = SCREEN_W + 30;
  obsType       = random(0, CACTUS_COUNT);
  prevObsType   = obsType;
  birdX         = 320;
  prevBirdX     = 320;
  birdY         = GROUND_Y - 30;
  prevBirdY     = birdY;
  cloud1X       = 80;  prevCloud1X = 80;
  cloud2X       = 30;  prevCloud2X = 30;
  mount1X       = 100; prevMount1X = 100;
  mount2X       = 40;  prevMount2X = 40;
  groundOffset  = 0;
  startTime     = millis();
  tft.fillScreen(COL_BLACK);
}

// =============================================
// SETUP / LOOP
// =============================================

void setup() {
  pinMode(TFT_BACKLIGHT, OUTPUT);
  digitalWrite(TFT_BACKLIGHT, HIGH);
  tft.initR(INITR_144GREENTAB);
  tft.setRotation(0);
  tft.fillScreen(COL_BLACK);
  pinMode(BTN_JUMP, INPUT_PULLUP);
  pinMode(BTN_DUCK, INPUT_PULLUP);
  randomSeed(analogRead(0));
  showStartScreen();
}

void loop() {
  bool jumpNow  = (digitalRead(BTN_JUMP) == LOW);
  bool duckNow  = (digitalRead(BTN_DUCK) == LOW);
  bool jumpEdge = jumpNow && !prevJump;
  prevJump = jumpNow;
  prevDuck = duckNow;

  // ---------- СТАРТ ----------
  if (gameState == STATE_START) {
    updateMenuBlink();
    if (jumpEdge) { resetGame(); gameState = STATE_PLAY; }
    delay(16);
    return;
  }

  // ---------- СМЕРТЬ ----------
  if (gameState == STATE_DEAD) {
    if (jumpEdge) { showStartScreen(); gameState = STATE_START; }
    delay(16);
    return;
  }

  // ========== ГРА ==========

  speed = 3 + (score / 8);
  if (speed > 9) speed = 9;

  // Зберігаємо попередній стан
  prevDinoY     = dinoY;
  prevIsDucking = isDucking;
  prevObsX      = obsX;
  prevObsType   = obsType;
  prevBirdX     = birdX;
  prevBirdY     = birdY;
  prevCloud1X   = cloud1X;
  prevCloud2X   = cloud2X;
  prevMount1X   = mount1X;
  prevMount2X   = mount2X;

  // Очищення
  erasePrevDino();
  erasePrevObs();
  erasePrevBird();
  eraseDecor();
  eraseGround();

  // --- Присідання ---
  isDucking = (duckNow && !isJumping);
  if (!isDucking && !isJumping) dinoY = GROUND_Y - 16;

  // --- Стрибок ---
  if (jumpEdge && !isJumping && !isDucking) {
    jumpVel  = 8;
    isJumping = true;
  }
  if (isJumping) {
    dinoY -= jumpVel;
    jumpVel--;
    if (dinoY >= GROUND_Y - 16) {
      dinoY     = GROUND_Y - 16;
      isJumping = false;
    }
  }

  // --- Анімація дино ---
  if (!isJumping && !isDucking)
    if (++animTick >= 5) { animTick = 0; animFrame = 1 - animFrame; }

  // --- Анімація птаха ---
  if (++birdAnimTick >= 8) { birdAnimTick = 0; birdAnim = 1 - birdAnim; }

  // --- Рух кактуса ---
  obsX -= speed;
  if (obsX < -18) {
    obsX    = SCREEN_W + random(20, 55);
    obsType = random(0, CACTUS_COUNT);
    score++;
  }

  // --- Рух птаха ---
  birdX -= speed + 2;
  if (birdX < -18) {
    birdX = SCREEN_W + random(40, 100);
    birdY = GROUND_Y - random(22, 48);
    score++;
  }

  // --- Декорації ---
  // Хмари — вдвічі повільніші за кактуси
  cloud1X -= max(1, speed / 2);
  cloud2X -= max(1, speed / 2);
  if (cloud1X < -18) cloud1X = SCREEN_W + random(10, 40);
  if (cloud2X < -18) cloud2X = SCREEN_W + random(10, 40);

  // Гори — дуже повільні (паралакс)
  mount1X -= max(1, speed / 3);
  mount2X -= max(1, speed / 3);
  if (mount1X < -18) mount1X = SCREEN_W + random(10, 30);
  if (mount2X < -18) mount2X = SCREEN_W + random(10, 30);

  groundOffset += speed;

  // --- Малювання ---
  drawDecor();
  drawGround();
  drawObs();
  drawBird();
  drawDino();

  // --- Колізії ---
  if (checkCactusHit() || checkBirdHit()) {
    gameState = STATE_DEAD;
    showGameOver();
    return;
  }

  // --- UI ---
  tft.setTextSize(1);
  tft.setTextColor(AMBER, COL_BLACK);
  tft.setCursor(2, 2);
  tft.print("XP:");
  tft.print(score);
  tft.setCursor(66, 2);
  tft.print("HI:");
  tft.print(highScore);

  delay(28);
}
