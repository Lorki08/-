  tft.setTextColor(RGB(180,200,255));tft.setCursor(T_PX+6,194);tft.print("LNS");tft.setTextColor(C_CYAN);tft.setCursor(T_PX+6,204);tft.print(t_lines);tft.print(" ");
}
bool t_valid(int px,int py,int type,int rot){
  for(int i=0;i<4;i++){int col=px+T_PIECES[type][rot][i][0],row=py+T_PIECES[type][rot][i][1];if(col<0||col>=T_COLS||row>=T_ROWS)return false;if(row>=0&&t_board[row][col]!=0)return false;}return true;
}
void t_lockPiece(){for(int i=0;i<4;i++){int col=t_px+T_PIECES[t_type][t_rot][i][0],row=t_py+T_PIECES[t_type][t_rot][i][1];if(row>=0&&row<T_ROWS&&col>=0&&col<T_COLS)t_board[row][col]=(uint8_t)(t_type+1);}}
void t_clearLines(){
  int cleared=0;
  for(int r=T_ROWS-1;r>=0;){bool full=true;for(int c=0;c<T_COLS;c++)if(!t_board[r][c]){full=false;break;}if(full){for(int c=0;c<T_COLS;c++)t_drawCell(c,r,C_WHITE);delay(60);for(int rr=r;rr>0;rr--)for(int c=0;c<T_COLS;c++)t_board[rr][c]=t_board[rr-1][c];for(int c=0;c<T_COLS;c++)t_board[0][c]=0;cleared++;}else{r--;}}
  if(cleared){t_lines+=cleared;t_score+=T_LINE_PTS[min(cleared,4)]*(t_level+1);if(t_score>t_best)t_best=t_score;t_level=min(9,t_lines/10);t_drawBoard();t_drawPanel();if(cleared==4){beep(1047,100);delay(120);beep(1047,100);}else beep(880,80);}
}
bool t_spawn(){t_type=t_next;t_next=random(7);t_rot=0;t_px=3;t_py=0;if(!t_valid(t_px,t_py,t_type,t_rot))return false;t_drawPanel();return true;}
void t_drawDead(){
