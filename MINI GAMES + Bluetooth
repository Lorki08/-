  tft.setTextSize(2);tft.setTextColor(C_YELLOW);
  tft.setCursor(20,110);tft.print("SCORE:");tft.print(t_score);tft.setCursor(20,135);tft.print("BEST: ");tft.print(t_best);tft.setCursor(20,160);tft.print("LINES:");tft.print(t_lines);tft.setCursor(20,185);tft.print("LEVEL:");tft.print(t_level);
  if(t_score>0&&t_score>=t_best){tft.setTextColor(C_CYAN);tft.setCursor(20,215);tft.print("<<< RECORD! >>>");}
