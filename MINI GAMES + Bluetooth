void spc_drawInv(int px,int py,int row,bool erase){
  if(erase){tft.fillRect(px,py,SPC_INV_W,SPC_INV_H,SC_BG);return;}
  uint16_t c=spc_invColor(row);
  if(row==0){
    tft.fillRect(px+4,py,6,2,c);tft.fillRect(px,py+2,14,2,c);tft.fillRect(px+2,py+4,10,2,c);
    tft.fillRect(px+2,py+6,4,2,c);tft.fillRect(px+8,py+6,4,2,c);
    if(spc_anim==0){tft.fillRect(px,py+8,4,2,c);tft.fillRect(px+10,py+8,4,2,c);}
    else{tft.fillRect(px+4,py+8,2,2,c);tft.fillRect(px+8,py+8,2,2,c);}
  } else if(row==1){
    tft.fillRect(px+2,py,10,2,c);tft.fillRect(px,py+2,14,4,c);
    tft.fillRect(px,py+6,4,2,c);tft.fillRect(px+10,py+6,4,2,c);
    if(spc_anim==0){tft.fillRect(px,py+8,2,2,c);tft.fillRect(px+12,py+8,2,2,c);}
    else{tft.fillRect(px+2,py+8,2,2,c);tft.fillRect(px+10,py+8,2,2,c);}
  } else {
    tft.fillRect(px,py,14,2,c);tft.fillRect(px,py+2,14,4,c);
    tft.fillRect(px,py+6,4,2,c);tft.fillRect(px+10,py+6,4,2,c);
    if(spc_anim==0){tft.fillRect(px+2,py+8,4,2,c);tft.fillRect(px+8,py+8,4,2,c);}
    else{tft.fillRect(px,py+8,4,2,c);tft.fillRect(px+10,py+8,4,2,c);}
  }
}
