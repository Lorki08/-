void t_drawBoard(){for(int r=0;r<T_ROWS;r++)for(int c=0;c<T_COLS;c++)t_drawCell(c,r,T_COLORS[t_board[r][c]]);}
void t_drawPiece(int px,int py,int type,int rot,bool erase=false){
  uint16_t c=erase?TC_EMPTY:T_COLORS[type+1];
  for(int i=0;i<4;i++){int col=px+T_PIECES[type][rot][i][0],row=py+T_PIECES[type][rot][i][1];if(row>=0&&row<T_ROWS&&col>=0&&col<T_COLS)t_drawCell(col,row,c);}
