#define SN_CELL 10
#define SN_COLS (SW/SN_CELL)
#define SN_ROWS ((SH-20)/SN_CELL)
#define SN_MAX  (SN_COLS*SN_ROWS)

SnakePt sn_body[SN_MAX]; int sn_len;
SnakePt sn_dir,sn_food;
int sn_score,sn_best; bool sn_dead;
int sn_frame,sn_spd;
bool sn_pUp,sn_pDown,sn_pLeft,sn_pRight,sn_pMenu;

int snX(int cx){return cx*SN_CELL;}
int snY(int cy){return cy*SN_CELL+20;}
void sn_placeFood(){bool ok=false;while(!ok){sn_food.x=random(SN_COLS);sn_food.y=random(SN_ROWS);ok=true;for(int i=0;i<sn_len;i++)if(sn_body[i].x==sn_food.x&&sn_body[i].y==sn_food.y){ok=false;break;}}}
void sn_drawCell(int cx,int cy,uint16_t c){tft.fillRect(snX(cx)+1,snY(cy)+1,SN_CELL-2,SN_CELL-2,c);}
void sn_drawUI(){
  tft.fillRect(0,0,SW,20,C_BLACK);tft.setTextSize(1);tft.setTextColor(RGB(0,220,60),C_BLACK);
  tft.setCursor(2,6);tft.print("SC:");tft.print(sn_score);tft.print("   ");
  tft.setCursor(100,6);tft.print("HI:");tft.print(sn_best);tft.print("   ");
  tft.setCursor(190,6);tft.print("LN:");tft.print(sn_len);
}
void sn_drawDead(){
  tft.fillScreen(C_BLACK);tft.drawRect(2,2,SW-4,SH-4,C_RED);tft.drawRect(5,5,SW-10,SH-10,C_YELLOW);
  tft.setTextSize(3);tft.setTextColor(C_RED);tft.setCursor(15,30);tft.print("GAME OVER");
  tft.setTextSize(2);tft.setTextColor(C_YELLOW);
  tft.setCursor(20,125);tft.print("SCORE:");tft.print(sn_score);
  tft.setCursor(20,150);tft.print("BEST: ");tft.print(sn_best);
  if(sn_score>0&&sn_score>=sn_best){tft.setTextColor(C_CYAN);tft.setCursor(20,180);tft.print("<<< RECORD! >>>");}
  tft.setTextSize(1);tft.setTextColor(C_WHITE);tft.setCursor(10,265);tft.print("UP=RESTART  MENU=MENU");
}
void snakeInit(){
  sn_dead=false;sn_score=0;sn_frame=0;sn_spd=10;sn_len=4;
  sn_dir={1,0};sn_pUp=sn_pDown=sn_pLeft=sn_pRight=sn_pMenu=false;
  for(int i=0;i<sn_len;i++){sn_body[i].x=(int8_t)(6-i);sn_body[i].y=5;}
  sn_placeFood();
  tft.fillScreen(RGB(10,20,10));
  for(int cx=0;cx<SN_COLS;cx++)for(int cy=0;cy<SN_ROWS;cy++)tft.fillRect(snX(cx)+1,snY(cy)+1,SN_CELL-2,SN_CELL-2,C_SGRID);
  for(int i=0;i<sn_len;i++)sn_drawCell(sn_body[i].x,sn_body[i].y,i==0?C_SHEAD:C_SBODY);
  sn_drawCell(sn_food.x,sn_food.y,C_SFOOD);sn_drawUI();
}
void snakeCycle(){
  bool cUp=bUp(),cDown=bDown(),cLeft=bLeft(),cRight=bRight(),cMenu=bMenu();
  if(cMenu&&!sn_pMenu){gs=GS_MENU;drawMenu();delay(200);return;}sn_pMenu=cMenu;
  if(sn_dead){if(cUp&&!sn_pUp)snakeInit();sn_pUp=cUp;delay(20);return;}
  if(cUp&&!sn_pUp&&sn_dir.y==0){sn_dir.x=0;sn_dir.y=-1;}
  if(cDown&&!sn_pDown&&sn_dir.y==0){sn_dir.x=0;sn_dir.y=1;}
  if(cLeft&&!sn_pLeft&&sn_dir.x==0){sn_dir.x=-1;sn_dir.y=0;}
  if(cRight&&!sn_pRight&&sn_dir.x==0){sn_dir.x=1;sn_dir.y=0;}
  sn_pUp=cUp;sn_pDown=cDown;sn_pLeft=cLeft;sn_pRight=cRight;
  sn_frame++;sn_spd=constrain(10-sn_score/5,3,10);
  if(sn_frame%sn_spd!=0){delay(30);return;}
  SnakePt nh;nh.x=(int8_t)(sn_body[0].x+sn_dir.x);nh.y=(int8_t)(sn_body[0].y+sn_dir.y);
  if(nh.x<0||nh.x>=SN_COLS||nh.y<0||nh.y>=SN_ROWS){sn_dead=true;if(sn_score>sn_best)sn_best=sn_score;beep(196,500);delay(520);sn_drawDead();return;}
  for(int i=0;i<sn_len-1;i++)if(sn_body[i].x==nh.x&&sn_body[i].y==nh.y){sn_dead=true;if(sn_score>sn_best)sn_best=sn_score;beep(196,500);delay(520);sn_drawDead();return;}
  bool ate=(nh.x==sn_food.x&&nh.y==sn_food.y);
  if(!ate){sn_drawCell(sn_body[sn_len-1].x,sn_body[sn_len-1].y,C_SGRID);for(int i=sn_len-1;i>0;i--)sn_body[i]=sn_body[i-1];}
  else{if(sn_len<SN_MAX){for(int i=sn_len;i>0;i--)sn_body[i]=sn_body[i-1];sn_len++;}else{for(int i=sn_len-1;i>0;i--)sn_body[i]=sn_body[i-1];}sn_score+=10;beep(880,60);sn_placeFood();sn_drawCell(sn_food.x,sn_food.y,C_SFOOD);}
  sn_body[0]=nh;
  if(sn_len>1)sn_drawCell(sn_body[1].x,sn_body[1].y,C_SBODY);
  sn_drawCell(sn_body[0].x,sn_body[0].y,C_SHEAD);sn_drawUI();delay(30);
}

