  tft.setTextColor(RGB(180,200,255));tft.setCursor(T_PX+6,52);tft.print("BEST");tft.setTextColor(RGB(120,150,255));tft.setCursor(T_PX+6,62);tft.print(t_best);tft.print("    ");
