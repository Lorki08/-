void dinoInit(){
  spc_dead=false;spc_win=false;spc_gx=0;spc_gy=0;spc_dir=1;
  spc_ship=SW/2;spc_score=0;spc_lives=SPC_LIVES;
  spc_bActive=false;spc_alive=SPC_COLS*SPC_ROWS;spc_anim=0;
  for(int i=0;i<SPC_IBMAX;i++)spc_ibActive[i]=false;
  for(int r=0;r<SPC_ROWS;r++)for(int c=0;c<SPC_COLS;c++)spc_grid[r][c]=true;
  spc_pLeft=spc_pRight=spc_pRot=spc_pMenu=false;
  spc_calcDelay();spc_nextMove=millis()+spc_moveDelay;spc_nextShoot=millis()+2000;
  tft.fillScreen(SC_BG);tft.drawFastHLine(0,SPC_SHIP_Y+SPC_SHIP_H+4,SW,SC_GNDL);
  tft.setTextSize(1);tft.setTextColor(RGB(0,100,0),SC_BG);
  tft.setCursor(4,SPC_SHIP_Y+SPC_SHIP_H+8);tft.print("L/R=move  ROT=fire  MENU=menu");
  for(int r=0;r<SPC_ROWS;r++)for(int c2=0;c2<SPC_COLS;c2++){int px,py;spc_invPos(r,c2,px,py);spc_drawInv(px,py,r,false);}
  spc_drawShip(spc_ship,SC_SHIP);spc_drawUI();
}
void dinoCycle(){
  bool cLeft=bLeft(),cRight=bRight(),cRot=bRot(),cMenu=bMenu();
  if(cMenu&&!spc_pMenu){gs=GS_MENU;drawMenu();delay(200);return;}spc_pMenu=cMenu;
  if(spc_dead||spc_win){if(cRot&&!spc_pRot)dinoInit();spc_pRot=cRot;delay(20);return;}
  int oldShip=spc_ship;
  if(cLeft)spc_ship-=4;if(cRight)spc_ship+=4;
  spc_ship=constrain(spc_ship,SPC_SHIP_W/2,SW-SPC_SHIP_W/2);
  if(oldShip!=spc_ship){spc_drawShip(oldShip,SC_BG);spc_drawShip(spc_ship,SC_SHIP);}
  if(cRot&&!spc_pRot&&!spc_bActive){spc_bActive=true;spc_bx=spc_ship;spc_by=SPC_SHIP_Y-8;beep(880,35);}
  if(spc_bActive){
    tft.fillRect(spc_bx-1,spc_by,2,6,SC_BG);spc_by-=SPC_BSPD;
    if(spc_by<24){spc_bActive=false;}
    else{
      bool hit=false;
      for(int r=0;r<SPC_ROWS&&!hit;r++)for(int c2=0;c2<SPC_COLS&&!hit;c2++){
        if(!spc_grid[r][c2])continue;
        int px,py;spc_invPos(r,c2,px,py);
        if(spc_bx>=px&&spc_bx<=px+SPC_INV_W&&spc_by>=py&&spc_by<=py+SPC_INV_H){
          spc_drawInv(px,py,r,true);spc_grid[r][c2]=false;spc_alive--;
          spc_score+=(2-r)*10+10;if(spc_score>spc_best)spc_best=spc_score;
          beep(660,50);spc_bActive=false;hit=true;spc_calcDelay();spc_drawUI();
          if(spc_alive==0){spc_win=true;beep(784,80);delay(100);beep(880,80);delay(100);beep(1047,200);spc_drawWin();return;}
        }
      }
      if(!hit)tft.fillRect(spc_bx-1,spc_by,2,6,SC_BULL);
    }
  }
  unsigned long now=millis();
  if(now>=spc_nextMove){
    spc_nextMove=now+spc_moveDelay;spc_anim=1-spc_anim;
    for(int r=0;r<SPC_ROWS;r++)for(int c2=0;c2<SPC_COLS;c2++){if(!spc_grid[r][c2])continue;int px,py;spc_invPos(r,c2,px,py);spc_drawInv(px,py,r,true);}
    int leftC=SPC_COLS,rightC=-1;
    for(int r=0;r<SPC_ROWS;r++)for(int c2=0;c2<SPC_COLS;c2++)if(spc_grid[r][c2]){leftC=min(leftC,c2);rightC=max(rightC,c2);}
    int newGx=spc_gx+spc_dir*3;
    int lx=SPC_GX0+newGx+leftC*SPC_GAP_X,rx=SPC_GX0+newGx+rightC*SPC_GAP_X+SPC_INV_W;
    if(lx<2||rx>SW-2){spc_dir=-spc_dir;spc_gy+=9;newGx=spc_gx;}
    spc_gx=newGx;
    int botR=-1;
    for(int r=SPC_ROWS-1;r>=0;r--){for(int c2=0;c2<SPC_COLS;c2++)if(spc_grid[r][c2]){botR=r;break;}if(botR>=0)break;}
    if(botR>=0){int py2=SPC_GY0+spc_gy+botR*SPC_GAP_Y+SPC_INV_H;if(py2>=SPC_SHIP_Y-8){spc_dead=true;spc_lives=0;if(spc_score>spc_best)spc_best=spc_score;beep(196,600);delay(630);spc_drawDead();return;}}
    for(int r=0;r<SPC_ROWS;r++)for(int c2=0;c2<SPC_COLS;c2++){if(!spc_grid[r][c2])continue;int px,py;spc_invPos(r,c2,px,py);spc_drawInv(px,py,r,false);}
  }
  if(now>=spc_nextShoot){
    spc_nextShoot=now+random(800,2500);int slot=-1;
    for(int i=0;i<SPC_IBMAX;i++)if(!spc_ibActive[i]){slot=i;break;}
    if(slot>=0){for(int tries=0;tries<12;tries++){int c2=random(SPC_COLS);for(int r=SPC_ROWS-1;r>=0;r--){if(spc_grid[r][c2]){int px,py;spc_invPos(r,c2,px,py);spc_ibActive[slot]=true;spc_ibx[slot]=px+SPC_INV_W/2;spc_iby[slot]=py+SPC_INV_H;tries=99;break;}}}}
  }
  for(int i=0;i<SPC_IBMAX;i++){
    if(!spc_ibActive[i])continue;
    tft.fillRect(spc_ibx[i]-1,spc_iby[i],2,6,SC_BG);spc_iby[i]+=SPC_IBSPD;
    if(spc_iby[i]>SPC_SHIP_Y+SPC_SHIP_H){spc_ibActive[i]=false;}
    else{int sx1=spc_ship-SPC_SHIP_W/2,sx2=spc_ship+SPC_SHIP_W/2;
      if(spc_ibx[i]>=sx1&&spc_ibx[i]<=sx2&&spc_iby[i]>=SPC_SHIP_Y){
        spc_ibActive[i]=false;spc_drawShip(spc_ship,SC_BG);spc_lives--;beep(196,280);delay(300);
        if(spc_lives<=0){spc_dead=true;if(spc_score>spc_best)spc_best=spc_score;beep(196,600);delay(630);spc_drawDead();return;}
        for(int f=0;f<3;f++){spc_drawShip(spc_ship,C_RED);delay(100);spc_drawShip(spc_ship,SC_BG);delay(100);}
        spc_drawShip(spc_ship,SC_SHIP);spc_drawUI();
      }else{tft.fillRect(spc_ibx[i]-1,spc_iby[i],2,6,SC_IBULL);}
    }
  }
  spc_pLeft=cLeft;spc_pRight=cRight;spc_pRot=cRot;delay(16);
}

