  t_drawPanel();t_spawn();t_drawPiece(t_px,t_py,t_type,t_rot);t_lastDrop=millis();
}
void tetrisCycle(){
  unsigned long now=millis();
  bool cUp=bUp(),cDown=bDown(),cLeft=bLeft(),cRight=bRight(),cRot=bRot(),cMenu=bMenu();
  if(cMenu&&!t_pMenu){gs=GS_MENU;drawMenu();delay(200);return;}
  if(t_dead){if(cRot&&!t_pRot)tetrisInit();t_pRot=cRot;t_pMenu=cMenu;delay(20);return;}
  if(cRot&&!t_pRot){int nr=(t_rot+1)%4;if(t_valid(t_px,t_py,t_type,nr)){t_drawPiece(t_px,t_py,t_type,t_rot,true);t_rot=nr;t_drawPiece(t_px,t_py,t_type,t_rot);beep(440,30);}else if(t_valid(t_px+1,t_py,t_type,nr)){t_drawPiece(t_px,t_py,t_type,t_rot,true);t_px++;t_rot=nr;t_drawPiece(t_px,t_py,t_type,t_rot);beep(440,30);}else if(t_valid(t_px-1,t_py,t_type,nr)){t_drawPiece(t_px,t_py,t_type,t_rot,true);t_px--;t_rot=nr;t_drawPiece(t_px,t_py,t_type,t_rot);beep(440,30);}}
  if(cLeft&&!t_pLeft&&t_valid(t_px-1,t_py,t_type,t_rot)){t_drawPiece(t_px,t_py,t_type,t_rot,true);t_px--;t_drawPiece(t_px,t_py,t_type,t_rot);}
  if(cRight&&!t_pRight&&t_valid(t_px+1,t_py,t_type,t_rot)){t_drawPiece(t_px,t_py,t_type,t_rot,true);t_px++;t_drawPiece(t_px,t_py,t_type,t_rot);}
  if(cDown&&!t_pDown&&t_valid(t_px,t_py+1,t_type,t_rot)){t_drawPiece(t_px,t_py,t_type,t_rot,true);t_py++;t_drawPiece(t_px,t_py,t_type,t_rot);t_score++;t_lastDrop=now;}
  if(cUp&&!t_pUp){t_drawPiece(t_px,t_py,t_type,t_rot,true);while(t_valid(t_px,t_py+1,t_type,t_rot)){t_py++;t_score+=2;}t_drawPiece(t_px,t_py,t_type,t_rot);t_lockPiece();beep(294,40);t_clearLines();if(!t_spawn()){t_dead=true;if(t_score>t_best)t_best=t_score;beep(196,600);delay(630);t_drawDead();}else{t_drawPiece(t_px,t_py,t_type,t_rot);t_drawPanel();}t_pUp=cUp;t_pDown=cDown;t_pLeft=cLeft;t_pRight=cRight;t_pRot=cRot;t_pMenu=cMenu;delay(16);return;}
  t_pUp=cUp;t_pDown=cDown;t_pLeft=cLeft;t_pRight=cRight;t_pRot=cRot;t_pMenu=cMenu;
  if((now-t_lastDrop)>=(unsigned long)T_SPEEDS[t_level]){t_lastDrop=now;if(t_valid(t_px,t_py+1,t_type,t_rot)){t_drawPiece(t_px,t_py,t_type,t_rot,true);t_py++;t_drawPiece(t_px,t_py,t_type,t_rot);}else{t_lockPiece();beep(294,40);t_clearLines();if(!t_spawn()){t_dead=true;if(t_score>t_best)t_best=t_score;beep(196,600);delay(630);t_drawDead();return;}t_drawPiece(t_px,t_py,t_type,t_rot);t_drawPanel();}}
  delay(16);
}

// ══════════════════════════════════════════════
//  SETUP / LOOP
// ══════════════════════════════════════════════
void setup(){
  Serial.begin(115200);
  pinMode(TFT_BL,OUTPUT);digitalWrite(TFT_BL,HIGH);
  pinMode(BTN_LEFT,INPUT_PULLUP);pinMode(BTN_DOWN,INPUT_PULLUP);
  pinMode(BTN_RIGHT,INPUT_PULLUP);pinMode(BTN_UP,INPUT_PULLUP);
  pinMode(BTN_ROT,INPUT_PULLUP);pinMode(BTN_MENU,INPUT_PULLUP);
  pinMode(BUZZ,OUTPUT);
  SPI.begin(18,-1,23,TFT_CS);delay(20);
  tft.init(SW,SH);delay(100);
  tft.setRotation(0);tft.invertDisplay(false);
  randomSeed(analogRead(34));

  // ── Bluetooth ──
  if(!SerialBT.begin("ESP32-GAMES")){
    Serial.println("Bluetooth FAILED");
  }else{
    Serial.println("Bluetooth OK: ESP32-GAMES");
  }

  int mel[]={659,659,659,523,659,784,392};
  int dur[]={100,100,100,100,100,200,200};
  for(int i=0;i<7;i++){beep(mel[i],dur[i]);delay(dur[i]+30);}
  noTone(BUZZ);
  gs=GS_MENU;drawMenu();
}

void loop(){
  btPoll(); // ← Bluetooth опитування
  switch(gs){
    case GS_MENU:     menuLoop();      break;
    case GS_BREAKOUT: breakoutCycle(); break;
    case GS_DINO:     dinoCycle();     break;
    case GS_SNAKE:    snakeCycle();    break;
    case GS_TETRIS:   tetrisCycle();   break;
  }
}
