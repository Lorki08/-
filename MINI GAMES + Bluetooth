// ─── Bluetooth стан кнопок ───────────────────
bool btLeft = false, btDown = false, btRight = false;
bool btUp   = false, btRot  = false, btMenu  = false;
bool btHadClient = false;

void btReleaseAll() {
  btLeft = btDown = btRight = btUp = btRot = btMenu = false;
}

void btHandleChar(char c) {
  switch (c) {
    case 'L': btLeft  = true;  break;
    case 'l': btLeft  = false; break;
    case 'D': btDown  = true;  break;
    case 'd': btDown  = false; break;
    case 'R': btRight = true;  break;
    case 'r': btRight = false; break;
    case 'U': btUp    = true;  break;
    case 'u': btUp    = false; break;
    case 'T': btRot   = true;  break;
    case 't': btRot   = false; break;
    case 'M': btMenu  = true;  break;
    case 'm': btMenu  = false; break;
    case 'X': btReleaseAll();  break;
  }
}

void btPoll() {
  while (SerialBT.available()) {
    btHandleChar((char)SerialBT.read());
  }
  bool hasClient = SerialBT.hasClient();
  if (!hasClient && btHadClient) btReleaseAll();
  btHadClient = hasClient;
}

