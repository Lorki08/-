void drawMenu(){
  tft.fillScreen(C_BLACK);
  tft.drawRect(2,2,SW-4,SH-4,C_YELLOW);
  tft.setTextSize(2); tft.setTextColor(C_YELLOW);
  tft.setCursor(20,18); tft.print("ESP32 GAMES");
  tft.setTextSize(1);
  const char* names[4]={"BREAKOUT","DINO RUNNER","SNAKE","TETRIS"};
  uint16_t    cols[4] ={RGB(0,220,255),C_GREEN,RGB(0,200,255),RGB(180,0,220)};
  for(int i=0;i<4;i++){
    if(menuSel==i){
      tft.fillRect(14,60+i*55,SW-28,42,RGB(20,20,20));
      tft.drawRect(14,60+i*55,SW-28,42,cols[i]);
      tft.setTextColor(cols[i]); tft.setCursor(24,68+i*55); tft.print(">");
    }
    tft.setTextColor(menuSel==i?cols[i]:(uint16_t)RGB(80,80,80));
    tft.setCursor(36,68+i*55); tft.print(names[i]);
  }
  tft.setTextColor(RGB(80,80,80));
  tft.setCursor(14,296); tft.print("A=UP  B=DOWN  ST=SELECT");
}

void menuLoop(){
  bool cA=btnA(),cB=btnB(),cSt=btnSt();
  if(cA&&!mx_prevA){menuSel=(menuSel+3)%4;beep(440,40);drawMenu();}
  if(cB&&!mx_prevB){menuSel=(menuSel+1)%4;beep(440,40);drawMenu();}
  if(cSt&&!mx_prevSt){
    beep(659,80); delay(100);
    switch(menuSel){
      case 0: gs=GS_BREAKOUT; breakoutInit(); break;
      case 1: gs=GS_DINO;     dinoInit();     break;
      case 2: gs=GS_SNAKE;    snakeInit();    break;
      case 3: gs=GS_TETRIS;   tetrisInit();   break;
    }
  }
  mx_prevA=cA; mx_prevB=cB; mx_prevSt=cSt;
}

