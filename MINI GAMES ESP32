  tft.setCursor(T_PX+6,26); tft.print("SCORE");
  tft.setTextColor(C_YELLOW); tft.setCursor(T_PX+6,36); tft.print(t_score); tft.print("    ");
  tft.setTextColor(RGB(180,200,255)); tft.setCursor(T_PX+6,52); tft.print("BEST");
  tft.setTextColor(RGB(120,150,255)); tft.setCursor(T_PX+6,62); tft.print(t_best); tft.print("    ");
  tft.setTextColor(RGB(180,200,255)); tft.setCursor(T_PX+6,78); tft.print("NEXT:");
  t_drawNext();
  tft.setCursor(T_PX+6,168); tft.setTextColor(RGB(180,200,255)); tft.print("LVL");
  tft.setTextColor(C_GREEN); tft.setCursor(T_PX+6,178); tft.print(t_level); tft.print(" ");
  tft.setCursor(T_PX+6,194); tft.setTextColor(RGB(180,200,255)); tft.print("LNS");
  tft.setTextColor(C_CYAN); tft.setCursor(T_PX+6,204); tft.print(t_lines); tft.print(" ");
