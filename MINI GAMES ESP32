void safeRect(int x,int y,int w,int h,uint16_t c){
  if(x>=SW||y>=SH||w<=0||h<=0)return;
  if(x<0){w+=x;x=0;} if(y<0){h+=y;y=0;}
  if(x+w>SW)w=SW-x; if(y+h>SH)h=SH-y;
  if(w>0&&h>0)tft.fillRect(x,y,w,h,c);
}
void beep(int f,int ms){ if(f>0)tone(BUZZ,f,ms); else noTone(BUZZ); }
bool btnA()    { return digitalRead(BTN_A)   ==LOW; }
bool btnB()    { return digitalRead(BTN_B)   ==LOW; }
bool btnC()    { return digitalRead(BTN_C)   ==LOW; }
bool btnD()    { return digitalRead(BTN_D)   ==LOW; }
bool btnSt()   { return digitalRead(BTN_ST)  ==LOW; }
bool btnMenu() { return digitalRead(BTN_MENU)==LOW; }

// Малювання спрайту з масштабом (scale=2 → кожен піксель = 2×2)
void drawScaledBmp(int x,int y,const uint8_t* bmp,int bmpW,int bmpH,
                   uint16_t fg,uint16_t bg,int scale){
  int bpr=(bmpW+7)/8;
  for(int row=0;row<bmpH;row++){
    for(int col=0;col<bmpW;col++){
      uint8_t b=pgm_read_byte(bmp+row*bpr+col/8);
      bool on=(b>>(7-(col&7)))&1;
      tft.fillRect(x+col*scale, y+row*scale, scale, scale, on?fg:bg);
    }
  }
}

