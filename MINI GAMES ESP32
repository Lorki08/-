#define PAD_Y       305
#define BALL_R       5
#define BRK_LIVES    3

const uint16_t BRK_ROWCOL[8]={
  RGB(220,0,0),RGB(220,100,0),RGB(220,200,0),RGB(0,200,0),
  RGB(0,180,255),RGB(0,50,220),RGB(180,0,220),RGB(180,180,180)
};

