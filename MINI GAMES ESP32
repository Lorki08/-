void setup(){
  Serial.begin(115200);
  pinMode(TFT_BL,   OUTPUT); digitalWrite(TFT_BL,HIGH);
  pinMode(BTN_A,    INPUT_PULLUP);
  pinMode(BTN_B,    INPUT_PULLUP);
  pinMode(BTN_C,    INPUT_PULLUP);
  pinMode(BTN_D,    INPUT_PULLUP);
  pinMode(BTN_MENU, INPUT_PULLUP);
  pinMode(BTN_ST,   INPUT_PULLUP);
  pinMode(BUZZ,     OUTPUT);
  SPI.begin(18,-1,23,TFT_CS); delay(20);
  tft.init(SW,SH); delay(100);
  tft.setRotation(0); tft.invertDisplay(false);
  randomSeed(analogRead(34));
  // Стартова мелодія
  int melody[]={659,659,659,523,659,784,392};
  int dur[]   ={100,100,100,100,100,200,200};
  for(int i=0;i<7;i++){beep(melody[i],dur[i]);delay(dur[i]+30);}
  noTone(BUZZ);
  gs=GS_MENU; drawMenu();
}

void loop(){
  switch(gs){
    case GS_MENU:     menuLoop();     break;
    case GS_BREAKOUT: breakoutCycle(); break;
    case GS_DINO:     dinoCycle();    break;
    case GS_SNAKE:    snakeCycle();   break;
    case GS_TETRIS:   tetrisCycle();  break;
  }
}
