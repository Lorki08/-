void brk_drawBrick(int col,int row,bool erase){
  int x=col*BRK_SLOT_W, y=BRK_Y0+row*BRK_SLOT_H;
  if(erase){ tft.fillRect(x,y,BRK_SLOT_W,BRK_SLOT_H,C_BLACK); return; }
  uint16_t c=BRK_ROWCOL[row];
  tft.fillRect(x+1,y+1,BRK_W,BRK_H,c);
  tft.drawFastHLine(x+1,y+1,BRK_W,C_WHITE);
  tft.drawFastVLine(x+1,y+1,BRK_H,C_WHITE);
  tft.drawFastHLine(x+1,y+BRK_H,BRK_W,C_BLACK);
  tft.drawFastVLine(x+BRK_W,y+1,BRK_H,C_BLACK);
}

void brk_drawPad(int cx,uint16_t c){
  tft.fillRoundRect(cx-PAD_W/2,PAD_Y,PAD_W,PAD_H,3,c);
}

void brk_drawBall(int bx,int by,uint16_t c){
