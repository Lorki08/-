void brk_drawBrick(int col,int row,bool erase){
  int x=col*BRK_SLOT_W, y=BRK_Y0+row*BRK_SLOT_H;
  if(erase){tft.fillRect(x,y,BRK_SLOT_W,BRK_SLOT_H,C_BLACK);return;}
  uint16_t c=BRK_ROWCOL[row];
  tft.fillRect(x+1,y+1,BRK_W,BRK_H,c);
  tft.drawFastHLine(x+1,y+1,BRK_W,C_WHITE); tft.drawFastVLine(x+1,y+1,BRK_H,C_WHITE);
  tft.drawFastHLine(x+1,y+BRK_H,BRK_W,C_BLACK); tft.drawFastVLine(x+BRK_W,y+1,BRK_H,C_BLACK);
}
void brk_drawPad(int cx,uint16_t c){tft.fillRoundRect(cx-PAD_W/2,PAD_Y,PAD_W,PAD_H,3,c);}
void brk_drawBall(int bx,int by,uint16_t c){tft.fillCircle(bx,by,BALL_R,c);}
void brk_drawUI(){
  tft.fillRect(0,0,SW,22,C_BLACK);
  tft.setTextSize(1);tft.setTextColor(C_WHITE,C_BLACK);
  tft.setCursor(2,7); tft.print("SC:"); tft.print(brk_score); tft.print("  ");
  tft.setCursor(90,7);tft.print("HI:"); tft.print(brk_best);  tft.print("  ");
  for(int i=0;i<BRK_LIVES;i++)
    tft.fillCircle(190+i*15,11,5,i<brk_lives?C_RED:RGB(40,40,40));
}
void brk_endScreen(bool win){
  tft.fillScreen(C_BLACK);
  uint16_t fc=win?C_GREEN:C_RED;
  tft.drawRect(2,2,SW-4,SH-4,fc); tft.drawRect(5,5,SW-10,SH-10,C_YELLOW);
  tft.setTextSize(3); tft.setTextColor(fc);
  tft.setCursor(win?30:15,30); tft.print(win?"YOU WIN!":"GAME OVER");
  tft.setTextSize(2); tft.setTextColor(C_YELLOW);
  tft.setCursor(20,125); tft.print("SCORE:"); tft.print(brk_score);
  tft.setCursor(20,150); tft.print("BEST: "); tft.print(brk_best);
  if(!win&&brk_score>0&&brk_score>=brk_best){tft.setTextColor(C_CYAN);tft.setCursor(20,180);tft.print("<<< RECORD! >>>");}
  tft.setTextSize(1); tft.setTextColor(C_WHITE);
  tft.setCursor(10,265); tft.print("ROT=RESTART   MENU=MENU");
}
void breakoutInit(){
  brk_dead=false;brk_win=false;brk_launched=false;
  brk_lives=BRK_LIVES;brk_score=0;brk_bricks=0;
  brk_pRot=false;brk_pMenu=false;
  for(int r=0;r<BRK_ROWS;r++)for(int c=0;c<BRK_COLS;c++)brk_grid[r][c]=1;
  brk_bricks=BRK_ROWS*BRK_COLS;
  brk_padX=SW/2;brk_ballX=SW/2;brk_ballY=PAD_Y-BALL_R-2;
  brk_bvx=3;brk_bvy=-5;
  tft.fillScreen(C_BLACK);
  tft.drawRect(0,22,SW,SH-22,RGB(50,50,80));
  for(int r=0;r<BRK_ROWS;r++)for(int c=0;c<BRK_COLS;c++)brk_drawBrick(c,r,false);
  brk_drawPad(brk_padX,C_CYAN);brk_drawBall(brk_ballX,brk_ballY,C_WHITE);brk_drawUI();
  tft.setTextSize(1);tft.setTextColor(RGB(80,80,80),C_BLACK);
  tft.setCursor(45,PAD_Y-14);tft.print("ROT = LAUNCH");
}
void breakoutCycle(){
  bool cL=bLeft(),cR=bRight(),cRot=bRot(),cMenu=bMenu();
  bool rotEdge=cRot&&!brk_pRot; brk_pRot=cRot;
  if(cMenu&&!brk_pMenu){gs=GS_MENU;drawMenu();delay(200);return;} brk_pMenu=cMenu;
  if(brk_dead||brk_win){if(rotEdge)breakoutInit();delay(20);return;}
  int oldPad=brk_padX;
  if(cL) brk_padX-=5;
  if(cR) brk_padX+=5;
  brk_padX=constrain(brk_padX,PAD_W/2,SW-PAD_W/2);
  if(rotEdge&&!brk_launched){
    brk_launched=true;
    tft.fillRect(35,PAD_Y-18,175,12,C_BLACK);
  }
  if(brk_launched){
    int nbx=brk_ballX+brk_bvx,nby=brk_ballY+brk_bvy;
    if(nbx-BALL_R<=0){brk_bvx=abs(brk_bvx);nbx=BALL_R+1;beep(440,20);}
    if(nbx+BALL_R>=SW-1){brk_bvx=-abs(brk_bvx);nbx=SW-BALL_R-2;beep(440,20);}
    if(nby-BALL_R<=23){brk_bvy=abs(brk_bvy);nby=24+BALL_R;beep(440,20);}
    int pL=brk_padX-PAD_W/2,pR=brk_padX+PAD_W/2;
    if(nby+BALL_R>=PAD_Y&&nby+BALL_R<=PAD_Y+PAD_H&&nbx>=pL&&nbx<=pR&&brk_bvy>0){
      brk_bvy=-abs(brk_bvy);
      brk_bvx=map(nbx-brk_padX,-PAD_W/2,PAD_W/2,-6,6);
      if(brk_bvx==0)brk_bvx=1;
      nby=PAD_Y-BALL_R-1;beep(523,30);
    }
    if(nby>SH+BALL_R){
      brk_lives--;beep(196,400);delay(420);
      brk_drawBall(brk_ballX,brk_ballY,C_BLACK);
      if(brk_lives<=0){brk_dead=true;if(brk_score>brk_best)brk_best=brk_score;brk_endScreen(false);return;}
      brk_ballX=brk_padX;brk_ballY=PAD_Y-BALL_R-2;
      brk_bvx=(random(2)?3:-3);brk_bvy=-5;brk_launched=false;brk_drawUI();
      tft.setTextSize(1);tft.setTextColor(RGB(80,80,80),C_BLACK);
      tft.setCursor(45,PAD_Y-14);tft.print("ROT = LAUNCH"); return;
    }
    bool hit=false;
    for(int side=0;side<2&&!hit;side++){
      int by2=(side==0)?nby-BALL_R:nby+BALL_R;
      int row=(by2-BRK_Y0)/BRK_SLOT_H,col=nbx/BRK_SLOT_W;
      if(row>=0&&row<BRK_ROWS&&col>=0&&col<BRK_COLS&&brk_grid[row][col]){
        brk_grid[row][col]=0;brk_bricks--;brk_score+=10;
        if(brk_score>brk_best)brk_best=brk_score;
        brk_drawBrick(col,row,true);brk_bvy=-brk_bvy;beep(880,30);hit=true;
        if(brk_bricks==0){brk_win=true;brk_endScreen(true);return;}
      }
    }
    for(int side=0;side<2&&!hit;side++){
      int bx2=(side==0)?nbx-BALL_R:nbx+BALL_R;
      int row=(nby-BRK_Y0)/BRK_SLOT_H,col=bx2/BRK_SLOT_W;
      if(row>=0&&row<BRK_ROWS&&col>=0&&col<BRK_COLS&&brk_grid[row][col]){
        brk_grid[row][col]=0;brk_bricks--;brk_score+=10;
        if(brk_score>brk_best)brk_best=brk_score;
        brk_drawBrick(col,row,true);brk_bvx=-brk_bvx;beep(880,30);hit=true;
        if(brk_bricks==0){brk_win=true;brk_endScreen(true);return;}
      }
    }
    brk_drawBall(brk_ballX,brk_ballY,C_BLACK);
    brk_ballX=nbx;brk_ballY=nby;
    brk_drawBall(brk_ballX,brk_ballY,C_WHITE);
  } else {
    brk_drawBall(brk_ballX,brk_ballY,C_BLACK);
    brk_ballX=brk_padX;
    brk_drawBall(brk_ballX,brk_ballY,C_WHITE);
  }
  if(oldPad!=brk_padX){brk_drawPad(oldPad,C_BLACK);brk_drawPad(brk_padX,C_CYAN);}
  brk_drawUI();delay(16);
}

