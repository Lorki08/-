    if(row>=0&&t_board[row][col]!=0)return false;
  }
  return true;
}
void t_lockPiece(){
  for(int i=0;i<4;i++){
    int col=t_px+T_PIECES[t_type][t_rot][i][0],row=t_py+T_PIECES[t_type][t_rot][i][1];
    if(row>=0&&row<T_ROWS&&col>=0&&col<T_COLS)t_board[row][col]=(uint8_t)(t_type+1);
  }
}
void t_clearLines(){
  int cleared=0;
  for(int r=T_ROWS-1;r>=0;){
    bool full=true;
    for(int c=0;c<T_COLS;c++)if(!t_board[r][c]){full=false;break;}
    if(full){
      for(int c=0;c<T_COLS;c++)t_drawCell(c,r,C_WHITE);delay(60);
      for(int rr=r;rr>0;rr--)for(int c=0;c<T_COLS;c++)t_board[rr][c]=t_board[rr-1][c];
      for(int c=0;c<T_COLS;c++)t_board[0][c]=0;cleared++;
    }else{r--;}
  }
  if(cleared){
    t_lines+=cleared;t_score+=T_LINE_PTS[min(cleared,4)]*(t_level+1);
    if(t_score>t_best)t_best=t_score;t_level=min(9,t_lines/10);
    t_drawBoard();t_drawPanel();
    if(cleared==4){beep(1047,100);delay(120);beep(1047,100);}else beep(880,80);
  }
}
bool t_spawn(){
  t_type=t_next;t_next=random(7);t_rot=0;t_px=3;t_py=0;
  if(!t_valid(t_px,t_py,t_type,t_rot))return false;
  t_drawPanel();return true;
}
void t_drawDead(){
  tft.fillScreen(C_BLACK);tft.drawRect(2,2,SW-4,SH-4,C_RED);tft.drawRect(5,5,SW-10,SH-10,C_YELLOW);
  tft.setTextSize(3);tft.setTextColor(C_RED);tft.setCursor(15,30);tft.print("GAME OVER");
  tft.setTextSize(2);tft.setTextColor(C_YELLOW);
  tft.setCursor(20,110);tft.print("SCORE:");tft.print(t_score);
  tft.setCursor(20,135);tft.print("BEST: ");tft.print(t_best);
  tft.setCursor(20,160);tft.print("LINES:");tft.print(t_lines);
  tft.setCursor(20,185);tft.print("LEVEL:");tft.print(t_level);
  if(t_score>0&&t_score>=t_best){tft.setTextColor(C_CYAN);tft.setCursor(20,215);tft.print("<<< RECORD! >>>");}
  tft.setTextSize(1);tft.setTextColor(C_WHITE);tft.setCursor(10,265);tft.print("ROT=RESTART  MENU=MENU");
}
void tetrisInit(){
  t_dead=false;t_score=0;t_level=0;t_lines=0;
  t_pUp=t_pDown=t_pLeft=t_pRight=t_pRot=t_pMenu=t_menuHolding=false;t_menuHold=0;
  memset(t_board,0,sizeof(t_board));t_next=random(7);
  tft.fillScreen(RGB(8,10,16));
  for(int r=0;r<T_ROWS;r++)for(int c=0;c<T_COLS;c++)t_drawCell(c,r,TC_EMPTY);
  tft.drawRect(T_GX-1,T_GY-1,T_COLS*T_CELL+2,T_ROWS*T_CELL+2,RGB(60,80,120));
  t_drawPanel();t_spawn();t_drawPiece(t_px,t_py,t_type,t_rot);t_lastDrop=millis();
}
void tetrisCycle(){
  unsigned long now=millis();
  bool cUp=bUp(),cDown=bDown(),cLeft=bLeft(),cRight=bRight(),cRot=bRot(),cMenu=bMenu();
  // MENU утримати 1 с
  if(cMenu&&!t_menuHolding){t_menuHolding=true;t_menuHold=now;}
  if(!cMenu)t_menuHolding=false;
  if(t_menuHolding&&(now-t_menuHold)>=1000){gs=GS_MENU;drawMenu();delay(200);return;}
  if(t_dead){if(cRot&&!t_pRot)tetrisInit();t_pRot=cRot;t_pMenu=cMenu;delay(20);return;}
  // ROT = обертання
  if(cRot&&!t_pRot){
    int nr=(t_rot+1)%4;
    if     (t_valid(t_px,t_py,t_type,nr)){t_drawPiece(t_px,t_py,t_type,t_rot,true);t_rot=nr;t_drawPiece(t_px,t_py,t_type,t_rot);beep(440,30);}
    else if(t_valid(t_px+1,t_py,t_type,nr)){t_drawPiece(t_px,t_py,t_type,t_rot,true);t_px++;t_rot=nr;t_drawPiece(t_px,t_py,t_type,t_rot);beep(440,30);}
    else if(t_valid(t_px-1,t_py,t_type,nr)){t_drawPiece(t_px,t_py,t_type,t_rot,true);t_px--;t_rot=nr;t_drawPiece(t_px,t_py,t_type,t_rot);beep(440,30);}
  }
  // LEFT / RIGHT
  if(cLeft &&!t_pLeft  &&t_valid(t_px-1,t_py,t_type,t_rot)){t_drawPiece(t_px,t_py,t_type,t_rot,true);t_px--;t_drawPiece(t_px,t_py,t_type,t_rot);}
  if(cRight&&!t_pRight &&t_valid(t_px+1,t_py,t_type,t_rot)){t_drawPiece(t_px,t_py,t_type,t_rot,true);t_px++;t_drawPiece(t_px,t_py,t_type,t_rot);}
  // DOWN = soft drop
  if(cDown&&!t_pDown&&t_valid(t_px,t_py+1,t_type,t_rot)){t_drawPiece(t_px,t_py,t_type,t_rot,true);t_py++;t_drawPiece(t_px,t_py,t_type,t_rot);t_score++;t_lastDrop=now;}
  // UP = hard drop
  if(cUp&&!t_pUp){
    t_drawPiece(t_px,t_py,t_type,t_rot,true);
    while(t_valid(t_px,t_py+1,t_type,t_rot)){t_py++;t_score+=2;}
    t_drawPiece(t_px,t_py,t_type,t_rot);
    t_lockPiece();beep(294,40);t_clearLines();
    if(!t_spawn()){t_dead=true;if(t_score>t_best)t_best=t_score;beep(196,600);delay(630);t_drawDead();}
    else{t_drawPiece(t_px,t_py,t_type,t_rot);t_drawPanel();}
    t_pUp=cUp;t_pDown=cDown;t_pLeft=cLeft;t_pRight=cRight;t_pRot=cRot;t_pMenu=cMenu;
    delay(16);return;
  }
  t_pUp=cUp;t_pDown=cDown;t_pLeft=cLeft;t_pRight=cRight;t_pRot=cRot;t_pMenu=cMenu;
  // Автопадіння
  if((now-t_lastDrop)>=(unsigned long)T_SPEEDS[t_level]){
    t_lastDrop=now;
    if(t_valid(t_px,t_py+1,t_type,t_rot)){t_drawPiece(t_px,t_py,t_type,t_rot,true);t_py++;t_drawPiece(t_px,t_py,t_type,t_rot);}
    else{t_lockPiece();beep(294,40);t_clearLines();
      if(!t_spawn()){t_dead=true;if(t_score>t_best)t_best=t_score;beep(196,600);delay(630);t_drawDead();return;}
      t_drawPiece(t_px,t_py,t_type,t_rot);t_drawPanel();}
  }
  delay(16);
}

