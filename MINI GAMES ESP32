void dinoInit(){
  d_dead=false; d_ducking=false; d_dinoY=DGY-D_RSH; d_vy=0; d_onGnd=true;
  d_frame=0; d_legF=0; d_score=0; d_spd=4; d_nextObs=SW+60;
  d_obsX=SW+100; d_obsType=random(CACTUS_COUNT);
  d_birdX=SW+200; d_birdY=DGY-D_RSH-random(30,80); d_birdF=0; d_birdFT=0;
  for(int i=0;i<2;i++){ d_cldX[i]=random(SW); d_cldY[i]=20+i*25; }
  d_pA=false; d_pB=false;
  d_drawBg(); d_drawDino(false); d_drawUI();
}

void dinoCycle(){
  bool cA=btnA(),cB=btnB(); bool jE=cA&&!d_pA; d_pA=cA; d_pB=cB;
  if(btnMenu()){gs=GS_MENU;drawMenu();delay(200);return;}
  if(d_dead){if(jE)dinoInit();delay(20);return;}

  d_frame++; d_spd=constrain(4+d_score/10,4,12);

  // Стрибок / присідання
  bool wasOnGnd=d_onGnd;
  d_ducking=cB&&d_onGnd;
  if(jE&&d_onGnd&&!d_ducking){d_vy=-13;d_onGnd=false;beep(784,50);}
  if(!d_onGnd){
    d_vy++; d_dinoY+=d_vy;
    if(d_dinoY>=DGY-D_RSH){d_dinoY=DGY-D_RSH;d_vy=0;d_onGnd=true;}
  }
  if(d_ducking) d_dinoY=DGY-D_RSH; // не рухається вгору
  if(d_frame%5==0&&d_onGnd&&!d_ducking) d_legF=1-d_legF;
  if(!d_onGnd) d_legF=0;

  // Птах анімація
  if(++d_birdFT>=7){d_birdFT=0;d_birdF=1-d_birdF;}

  // Рух перешкод
  int prevOx=d_obsX; d_obsX-=d_spd;
  if(d_obsX<-(CACTUSES[d_obsType].w*D_SCALE)){
    d_drawCactus(prevOx,d_obsType,true);
    d_obsX=SW+random(40,100); d_obsType=random(CACTUS_COUNT);
    d_score++; beep(523,35);
  }
  int prevBx=d_birdX,prevBy=d_birdY; d_birdX-=d_spd+2;
  if(d_birdX<-36){
    d_drawBird(prevBx,prevBy,true);
    d_birdX=SW+random(80,200); d_birdY=DGY-D_RSH-random(10,90); d_score++;
  }

  // Хмари
  for(int i=0;i<2;i++){
    d_drawCld(d_cldX[i],d_cldY[i],true);
    d_cldX[i]-=1; if(d_cldX[i]<-36)d_cldX[i]=SW+random(20,60);
    d_drawCld(d_cldX[i],d_cldY[i],false);
  }

  // Перемалювання
  d_drawDino(true);
  d_drawCactus(d_obsX,d_obsType,false);
  d_drawBird(d_birdX,d_birdY,false);
  d_drawDino(false);
  tft.fillRect(0,DGY,SW,5,C_DGND);
  if(d_frame%30==0) d_score++;

  // Колізії
  int dx1=DINO_X+4, dx2=DINO_X+D_RSW-4;
  int dy1=d_dinoY+(d_ducking?D_RSH/2:4), dy2=d_dinoY+D_RSH-2;
  // кактус
  const CactusType& ct=CACTUSES[d_obsType];
  int ox1=d_obsX+2, ox2=d_obsX+ct.w*D_SCALE-2;
  int oy1=DGY-ct.h*D_SCALE+ct.topOffset*D_SCALE, oy2=DGY;
  bool hit=(dx2>ox1&&dx1<ox2&&dy2>oy1&&dy1<oy2);
  // птах
  if(!hit){
    int bx1=d_birdX+4,bx2=d_birdX+28,by1=d_birdY+2,by2=d_birdY+14;
    hit=(dx2>bx1&&dx1<bx2&&dy2>by1&&dy1<by2);
  }
  if(hit){
    d_dead=true; if(d_score>d_best)d_best=d_score;
    beep(196,500); delay(520); d_drawDead(); return;
  }
  d_drawUI(); delay(28);
}

